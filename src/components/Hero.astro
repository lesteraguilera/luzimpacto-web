---
import { getLang } from "../lib/i18n";
const lang = getLang(Astro.url);
const isEn = lang === "en";

const t = {
  eyebrow: isEn ? "LUZ Impacto Foundation · Costa Rica" : "Fundación LUZ Impacto · Costa Rica",
  ctaDonate: isEn ? "Give now" : "Donar ahora",
  ctaOther: isEn ? "Other ways to help" : "Otras formas de sumarte",
  videoAlt: isEn
    ? "Youth at a school in Costa Rica during a LUZ Impacto event"
    : "Jóvenes en un colegio de Costa Rica durante un evento de LUZ Impacto",
  getInvolvedPath: isEn ? "/en/get-involved" : "/sumate",
};
---

<section class="hero">
  <div class="container">
    <div>
      <div class="eyebrow hero-eyebrow">{t.eyebrow}</div>
      {isEn ? (
        <h1>
          Bringing<br>
          Christ's love<br>
          <span class="marker">to schools.</span>
        </h1>
      ) : (
        <h1>
          Llevamos el<br>
          Amor de Cristo<br>
          <span class="marker">a los colegios.</span>
        </h1>
      )}
      <p class="lede">
        {isEn
          ? "Thousands of young people spend eleven years in Costa Rica's schools without ever hearing the gospel. We're changing that — one school at a time, until we reach every one."
          : "Miles de jóvenes pasan once años en colegios costarricenses sin escuchar nunca el evangelio. Vamos a cambiar eso, colegio por colegio, hasta llegar a cada uno."
        }
      </p>
      <div class="ctas">
        <a href="#donar" class="btn btn-yellow">{t.ctaDonate} <span class="arrow">→</span></a>
        <a href={t.getInvolvedPath} class="btn btn-ghost-light">{t.ctaOther} <span class="arrow">→</span></a>
      </div>
    </div>
    <div class="hero-image">
      <video
        class="hero-video"
        src="/assets/photos/hero.mp4"
        poster="/assets/photos/hero-poster.jpg"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label={t.videoAlt}
      ></video>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--charcoal);
    color: var(--on-dark);
    padding: 120px 0 100px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(252,211,77,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero .container {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
  }
  .hero h1 { color: var(--on-dark); margin-bottom: 24px; }
  .hero h1 :global(.marker) {
    font-family: "Fraunces", serif;
    font-weight: 600;
  }
  .hero .lede {
    color: var(--on-dark-soft);
    max-width: 540px;
    margin-bottom: 36px;
    font-weight: 400;
  }
  .ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-image {
    border-radius: 20px;
    aspect-ratio: 4/5;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    position: relative;
  }
  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  @media (max-width: 900px) {
    .hero .container { grid-template-columns: 1fr; gap: 32px; }
    .hero-image { aspect-ratio: 4/3; }
  }
  @media (max-width: 600px) {
    .hero { padding: 64px 0 48px; }
  }
</style>

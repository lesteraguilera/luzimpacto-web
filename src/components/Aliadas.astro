---
// Iglesias aliadas — banda con placeholders
---

<section class="aliadas">
  <div class="container">
    <div class="head">
      <h3>30+ iglesias aliadas</h3>
      <div class="sub">Una red en todo Costa Rica<br>que recibe a los jóvenes que evangelizamos.</div>
    </div>
    <div class="aliadas-band">
      {[1,2,3,4,5,6].map((i) => (
        <div class="aliada-logo">Logo<br>iglesia {i}</div>
      ))}
    </div>
    <div class="badge-wrap"><span class="pendiente-badge">Logos pendientes</span></div>
  </div>
</section>

<style>
  .aliadas {
    background: var(--bg);
    padding: 80px 0;
    border-top: 1px solid var(--line);
  }
  .head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 40px;
  }
  .head h3 {
    font-family: "Inter", sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 12px;
  }
  .sub {
    font-family: "Fraunces", serif;
    font-size: 26px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
  }
  .aliadas-band {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
  }
  .aliada-logo {
    background: white;
    aspect-ratio: 3/2;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Fraunces", serif;
    font-size: 13px;
    color: var(--ink-faint);
    border: 1px dashed var(--line);
    text-align: center;
    padding: 8px;
  }
  .badge-wrap { text-align: center; margin-top: 24px; }

  @media (max-width: 900px) {
    .aliadas-band { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .aliadas-band { grid-template-columns: repeat(2, 1fr); }
  }
</style>

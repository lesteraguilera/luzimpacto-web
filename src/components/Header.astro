---
// Header sticky con logo + nav + toggle ES/EN + CTA + drawer móvil
---

<header class="site-header">
  <div class="container">
    <a href="/" class="header-logo" aria-label="LUZ Impacto · Inicio">
      <span class="luz-logo-img size-sm"></span>
    </a>
    <nav class="nav-main">
      <a href="/nosotros">Nosotros</a>
      <a href="/que-hacemos">Qué hacemos</a>
      <a href="/impacto">Impacto</a>
      <a href="/fotos">Fotos</a>
      <a href="/contacto">Contacto</a>
    </nav>
    <div class="nav-tools">
      <a href="/sumate" class="btn btn-dark btn-sm">Sumate <span class="arrow">→</span></a>
      <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" id="navToggle">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Drawer fuera del header para evitar stacking-context bug -->
<div class="nav-drawer" id="navDrawer" aria-hidden="true">
  <div class="drawer-inner">
    <a href="/">Inicio</a>
    <a href="/nosotros">Nosotros</a>
    <a href="/que-hacemos">Qué hacemos</a>
    <a href="/impacto">Impacto</a>
    <a href="/fotos">Fotos</a>
    <a href="/contacto">Contacto</a>
    <div class="drawer-ctas">
      <a href="/#donar" class="btn btn-yellow drawer-cta">Donar ahora <span class="arrow">→</span></a>
      <a href="/sumate" class="btn btn-dark drawer-cta">Sumate a la misión <span class="arrow">→</span></a>
      <a href="https://wa.me/50685493929" class="btn btn-ghost-dark drawer-cta drawer-cta-wa" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const toggle = document.getElementById('navToggle');
    const drawer = document.getElementById('navDrawer');
    if (!toggle || !drawer) return;
    const setState = (open) => {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
      document.body.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') !== 'true';
      setState(open);
    });
    drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setState(false)));
  })();
</script>

<style>
  .site-header {
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
    background: rgba(250,247,242,0.92);
  }
  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .header-logo { text-decoration: none; }
  .nav-main {
    display: flex;
    gap: 32px;
    flex: 1;
    justify-content: center;
  }
  .nav-main a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-main a:hover { color: var(--charcoal); }
  .nav-tools {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .lang-toggle {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
  }
  .lang-toggle .active { color: var(--charcoal); }

  .nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 8px;
    position: relative;
  }
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--charcoal);
    margin: 5px 0;
    transition: transform 0.25s, opacity 0.25s;
    border-radius: 2px;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-drawer {
    position: fixed;
    inset: 0;
    padding-top: 80px;
    background: var(--bg);
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 150;
    visibility: hidden;
    overflow-y: auto;
  }
  .nav-drawer[aria-hidden="false"] {
    transform: translateY(0);
    visibility: visible;
  }
  .drawer-inner {
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .drawer-inner a {
    font-family: "Fraunces", serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    letter-spacing: -0.01em;
  }
  .drawer-ctas {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-bottom: none !important;
    padding: 0 !important;
  }
  .drawer-cta {
    font-family: "Inter", sans-serif !important;
    font-size: 16px !important;
    border-bottom: none !important;
    padding: 16px 26px !important;
    align-self: stretch;
    text-align: center;
    justify-content: center;
  }
  .drawer-cta-wa { font-size: 14px !important; padding: 12px 26px !important; }

  @media (max-width: 900px) {
    .nav-main { display: none; }
    .nav-tools .lang-toggle { display: none; }
    .nav-tools .btn { display: none; }
    .nav-toggle { display: block; }
  }
</style>

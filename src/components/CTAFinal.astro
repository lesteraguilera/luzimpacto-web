---
import { getLang } from "../lib/i18n";
const lang = getLang(Astro.url);
const isEn = lang === "en";

// Props opcionales. Si no se pasan, se usa el copy default.
// `title` admite HTML (br + span class="marker") porque viene de strings literales del repo.
interface Props {
  title?: string;
  description?: string;
  ctaJoinLabel?: string;
  ctaTalkLabel?: string;
}
const { title, description, ctaJoinLabel, ctaTalkLabel } = Astro.props;

const t = {
  defaultTitle: isEn
    ? `There's a generation<br><span class="marker">waiting to be reached.</span>`
    : `Hay una generación<br><span class="marker">esperando ser alcanzada.</span>`,
  defaultDesc: isEn
    ? "Every day without you, there's a young person in a Costa Rican school looking for hope. Join us and let's be light together."
    : "Cada día sin vos, hay un joven en un colegio de Costa Rica buscando esperanza. Sumate y seamos luz juntos.",
  defaultJoin: isEn ? "Join the mission" : "Sumate a la misión",
  defaultTalk: isEn ? "Talk to us on WhatsApp" : "Hablemos por WhatsApp",
  joinPath: isEn ? "/en/get-involved" : "/sumate",
  waLink: isEn
    ? "https://wa.me/50685493929?text=Hello%20LUZ%2C%20I%20want%20to%20know%20more"
    : "https://wa.me/50685493929?text=Hola%20LUZ%2C%20quiero%20saber%20m%C3%A1s",
};

const finalTitle = title ?? t.defaultTitle;
const finalDesc = description ?? t.defaultDesc;
const finalJoin = ctaJoinLabel ?? t.defaultJoin;
const finalTalk = ctaTalkLabel ?? t.defaultTalk;
---

<section class="cta-final">
  <div class="container">
    <h2 set:html={finalTitle}></h2>
    <p>{finalDesc}</p>
    <div class="ctas">
      <a href={t.joinPath} class="btn btn-yellow">{finalJoin} <span class="arrow">→</span></a>
      <a href={t.waLink} target="_blank" rel="noopener" class="btn btn-ghost-light">{finalTalk} <span class="arrow">→</span></a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: var(--charcoal);
    color: var(--on-dark);
    padding: 100px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-final::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(252,211,77,0.06) 0%, transparent 60%);
    pointer-events: none;
  }
  .cta-final h2 { color: var(--on-dark); margin-bottom: 20px; }
  .cta-final h2 :global(.marker) {
    font-family: "Fraunces", serif;
    font-weight: 600;
  }
  .cta-final p {
    color: var(--on-dark-soft);
    font-size: 18px;
    max-width: 540px;
    margin: 0 auto 32px;
  }
  .ctas {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .cta-final { padding: 80px 0; }
  }
</style>

---
// Bloque emocional con cita bíblica (mientras no haya testimonio real)
// Cuando llegue uno real, este componente vuelve a su forma de testimonio
---

<section class="testimonio" id="impacto">
  <div class="container">
    <div class="quote-mark">"</div>
    <div class="quote">
      Vosotros sois la <span class="highlight">luz</span> del mundo;<br>
      una ciudad asentada sobre un monte<br>
      no se puede esconder.
    </div>
    <div class="cite">— Jesús · Mateo 5:14</div>
  </div>
</section>

<style>
  .testimonio {
    background: var(--charcoal);
    color: var(--on-dark);
    padding: 120px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .testimonio::before {
    content: "";
    position: absolute;
    top: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(252,211,77,0.10) 0%, transparent 70%);
    pointer-events: none;
  }
  .testimonio::after {
    content: "";
    position: absolute;
    bottom: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(252,211,77,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .quote-mark {
    font-family: "Fraunces", serif;
    font-size: 120px;
    color: var(--yellow);
    line-height: 0.5;
    margin-bottom: 20px;
    opacity: 0.5;
  }
  .quote {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-weight: 500;
    font-size: clamp(26px, 4vw, 44px);
    line-height: 1.35;
    color: var(--on-dark);
    max-width: 900px;
    margin: 0 auto 24px;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
  }
  .highlight { color: var(--yellow); font-style: normal; font-weight: 600; }
  .cite {
    font-family: "Inter", sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--on-dark-soft);
  }

  .impact-line {
    margin-top: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }
  .impact-item { text-align: center; }
  .impact-num {
    font-family: "Fraunces", serif;
    font-size: clamp(40px, 5vw, 56px);
    font-weight: 600;
    color: var(--yellow);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .impact-label {
    margin-top: 8px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--on-dark-soft);
    font-weight: 600;
  }
  .impact-sep {
    width: 1px;
    height: 48px;
    background: rgba(255,255,255,0.15);
  }

  @media (max-width: 700px) {
    .testimonio { padding: 80px 0; }
    .impact-line { gap: 24px; margin-top: 56px; }
    .impact-sep { display: none; }
  }
</style>

---
import { getLang } from "../lib/i18n";
const lang = getLang(Astro.url);
const isEn = lang === "en";

const t = {
  label: isEn ? "Give" : "Donar",
  aria: isEn ? "Give now" : "Donar ahora",
};
---

<a href="#donar" class="floating-donate" id="floatingDonate" aria-label={t.aria}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>
  </svg>
  <span class="fd-label">{t.label}</span>
</a>

<script is:inline>
  (function() {
    const btn = document.getElementById('floatingDonate');
    if (!btn) return;

    let lastY = window.scrollY;
    let visible = false;
    let scrollingDown = false;

    const update = () => {
      const y = window.scrollY;
      scrollingDown = y > lastY;
      lastY = y;

      // Visible solo si: scrolleó >200px Y no está scrolleando hacia abajo activamente
      const should = y > 200 && !scrollingDown;
      if (should !== visible) {
        btn.classList.toggle('visible', should);
        visible = should;
      }
    };
    window.addEventListener('scroll', update, { passive: true });

    // Cuando para de scrollear, mostrar
    let scrollTimer;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        if (window.scrollY > 200) {
          btn.classList.add('visible');
          visible = true;
        }
      }, 200);
    }, { passive: true });

    update();

    // Ocultar cuando se abre el modal de donación
    const modal = document.getElementById('donarModal');
    if (modal) {
      const observer = new MutationObserver(() => {
        if (modal.getAttribute('aria-hidden') === 'false') {
          btn.classList.add('hidden-by-modal');
        } else {
          btn.classList.remove('hidden-by-modal');
        }
      });
      observer.observe(modal, { attributes: true, attributeFilter: ['aria-hidden'] });
    }

    // Ocultar cuando se abre el drawer de navegación
    const drawer = document.getElementById('navDrawer');
    if (drawer) {
      const observer = new MutationObserver(() => {
        if (drawer.getAttribute('aria-hidden') === 'false') {
          btn.classList.add('hidden-by-modal');
        } else {
          btn.classList.remove('hidden-by-modal');
        }
      });
      observer.observe(drawer, { attributes: true, attributeFilter: ['aria-hidden'] });
    }
  })();
</script>

<style>
  .floating-donate {
    position: fixed;
    bottom: 16px;
    right: 16px;
    z-index: 90;
    display: none;
    align-items: center;
    gap: 6px;
    padding: 11px 18px 11px 14px;
    background: var(--yellow);
    color: var(--charcoal);
    text-decoration: none;
    border-radius: 100px;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    box-shadow: 0 6px 18px rgba(252,211,77,0.35), 0 2px 8px rgba(0,0,0,0.12);
    transform: translateY(80px);
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    pointer-events: none;
  }
  .floating-donate svg {
    width: 17px;
    height: 17px;
    fill: currentColor;
    stroke-width: 0;
  }
  .floating-donate.visible {
    transform: translateY(0);
    opacity: 0.92;
    pointer-events: auto;
  }
  .floating-donate.visible:hover,
  .floating-donate.visible:focus-visible {
    opacity: 1;
  }
  .floating-donate.hidden-by-modal {
    transform: translateY(80px);
    opacity: 0;
    pointer-events: none;
  }
  .floating-donate:active {
    transform: translateY(0) scale(0.95);
  }

  @media (max-width: 900px) {
    .floating-donate { display: inline-flex; }
  }
</style>

---
import { getLang } from "../lib/i18n";
const lang = getLang(Astro.url);
const isEn = lang === "en";

const t = {
  schools: isEn ? "Schools visited" : "Colegios visitados",
  schoolsSub: isEn ? "across Costa Rica" : "en todo Costa Rica",
  youth: isEn ? "Youth reached" : "Jóvenes alcanzados",
  youthSub: isEn ? "in school events" : "en eventos en colegios",
  churches: isEn ? "Partner churches" : "Iglesias aliadas",
  churchesSub: isEn ? "across all 7 provinces" : "red en las 7 provincias",
  provinces: isEn ? "Provinces reached" : "Provincias alcanzadas",
  provincesSub: isEn ? "working toward the seventh" : "y vamos por la última",
};
---

<div class="metrics">
  <div class="container">
    <div class="metrics-band">
      <div class="metric">
        <div class="num"><span class="count" data-target="60">60</span><span class="plus">+</span></div>
        <div class="label">{t.schools}</div>
        <div class="sub">{t.schoolsSub}</div>
      </div>
      <div class="metric">
        <div class="num"><span class="count" data-target="50" data-suffix="K">50K</span><span class="plus">+</span></div>
        <div class="label">{t.youth}</div>
        <div class="sub">{t.youthSub}</div>
      </div>
      <div class="metric">
        <div class="num"><span class="count" data-target="30">30</span><span class="plus">+</span></div>
        <div class="label">{t.churches}</div>
        <div class="sub">{t.churchesSub}</div>
      </div>
      <div class="metric">
        <div class="num">6<span class="of">/7</span></div>
        <div class="label">{t.provinces}</div>
        <div class="sub">{t.provincesSub}</div>
      </div>
    </div>
  </div>
</div>

<style>
  .metrics {
    background: var(--charcoal);
    color: var(--on-dark);
    padding: 0 0 80px;
  }
  .metrics-band {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .metric {
    padding: 56px 24px;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.08);
  }
  .metric:last-child { border-right: none; }
  .metric .num {
    font-family: "Fraunces", serif;
    font-size: clamp(48px, 6vw, 72px);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--yellow);
  }
  .metric .num .plus, .metric .num .of { font-size: 0.55em; vertical-align: super; opacity: 0.7; }
  .metric .label {
    margin-top: 14px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--on-dark);
    font-weight: 600;
  }
  .metric .sub {
    margin-top: 6px;
    font-size: 12px;
    color: var(--on-dark-soft);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  @media (max-width: 600px) {
    .metrics { padding: 0 0 56px; }
    .metrics-band { grid-template-columns: repeat(2, 1fr); }
    .metric { padding: 32px 16px; }
    .metric:nth-child(2) { border-right: none; }
    .metric:nth-child(1), .metric:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,0.08); }
  }
</style>

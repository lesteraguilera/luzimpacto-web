---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import CTAFinal from "../components/CTAFinal.astro";
import Footer from "../components/Footer.astro";
import MapaCR from "../components/MapaCR.astro";

const provincias = [
  { nombre: "San José", visitada: true },
  { nombre: "Alajuela", visitada: true },
  { nombre: "Cartago", visitada: true },
  { nombre: "Heredia", visitada: true },
  { nombre: "Guanacaste", visitada: true },
  { nombre: "Puntarenas", visitada: false },
  { nombre: "Limón", visitada: true },
];
const visitadas = provincias.filter(p => p.visitada).length;
---

<BaseLayout title="Impacto · LUZ Impacto" description="El alcance real de LUZ Impacto en Costa Rica: colegios visitados, jóvenes alcanzados, iglesias aliadas.">
  <Header />

  <PageHero
    eyebrow="Impacto"
    title="Cifras reales.<br><span class='marker'>Vidas reales.</span>"
    lede="Cada número representa colegios reales, jóvenes reales que escucharon el evangelio, iglesias reales que abrieron sus puertas."
  />

  <section class="metricas-big">
    <div class="container">
      <div class="grid">
        <div class="met">
          <div class="num"><span class="count" data-target="60">0</span><span class="plus">+</span></div>
          <div class="label">Colegios visitados</div>
          <p>Cada visita es coordinada con dirección académica y adaptada al contexto del colegio.</p>
        </div>
        <div class="met">
          <div class="num"><span class="count" data-target="50" data-suffix="K">0</span><span class="plus">+</span></div>
          <div class="label">Jóvenes alcanzados</div>
          <p>Miles de estudiantes han escuchado el mensaje de Cristo en eventos realizados con LUZ.</p>
        </div>
        <div class="met">
          <div class="num"><span class="count" data-target="30">0</span><span class="plus">+</span></div>
          <div class="label">Iglesias aliadas</div>
          <p>Una red de iglesias evangélicas en todo el país recibe a los jóvenes que reciben a Cristo.</p>
        </div>
        <div class="met">
          <div class="num">{visitadas}<span class="of">/7</span></div>
          <div class="label">Provincias alcanzadas</div>
          <p>Hemos llevado el mensaje a colegios en {visitadas} de las 7 provincias de Costa Rica.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <MapaCR />
    </div>
  </section>

  <section class="section">
    <div class="cinema-wrap">
      <div class="cinema-card">
        <img
          class="cinema-photo"
          src="/assets/photos/gallery/large/foto_27.jpg"
          alt="Una líder de LUZ Impacto abrazando a una estudiante tras un evento"
          loading="lazy"
        />
        <div class="cinema-overlay"></div>
        <div class="cinema-content">
          <div class="cinema-quote-mark">"</div>
          <div class="cinema-pull">Dios me agarró.</div>
          <p class="cinema-rest">
            Esa tarde no sé cómo explicarlo mejor. Mis amigas y yo lloramos como nunca, y desde ese día somos diferentes. <span class="cinema-em">Ya no me siento sola en lo que sentía.</span>
          </p>
        </div>
      </div>
      <p class="impacto-note">Recopilamos testimonios con permiso explícito de cada persona o de sus tutores. Pronto sumaremos más voces de jóvenes, pastores y voluntarios.</p>
    </div>
  </section>

  <CTAFinal />
  <Footer />
</BaseLayout>

<style>
  .metricas-big {
    background: var(--charcoal);
    color: var(--on-dark);
    padding: 80px 0;
  }
  .metricas-big .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .metricas-big .met {
    padding: 24px;
    border-left: 1px solid rgba(255,255,255,0.1);
  }
  .metricas-big .met:first-child { border-left: none; }
  .metricas-big .num {
    font-family: "Fraunces", serif;
    font-size: clamp(48px, 6vw, 72px);
    font-weight: 600;
    color: var(--yellow);
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .metricas-big .num .plus, .metricas-big .num .of { font-size: 0.55em; opacity: 0.7; }
  .metricas-big .label {
    margin: 12px 0;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--on-dark);
  }
  .metricas-big .met p {
    font-size: 14px;
    color: var(--on-dark-soft);
    margin-bottom: 0;
    line-height: 1.55;
  }

  .cinema-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .cinema-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    box-shadow: 0 30px 80px rgba(0,0,0,0.2);
  }
  .cinema-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .cinema-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 30%, rgba(0,0,0,0.55) 65%, rgba(0,0,0,0.95) 100%);
    pointer-events: none;
  }
  .cinema-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 56px 64px;
    color: white;
    z-index: 2;
  }
  .cinema-quote-mark {
    font-family: "Fraunces", serif;
    font-size: 96px;
    line-height: 0.3;
    color: var(--yellow);
    opacity: 0.7;
    margin-bottom: 24px;
  }
  .cinema-pull {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-weight: 600;
    font-size: clamp(40px, 6vw, 84px);
    line-height: 1;
    color: var(--yellow);
    letter-spacing: -0.02em;
    margin-bottom: 22px;
    text-shadow: 0 4px 28px rgba(0,0,0,0.6);
  }
  .cinema-rest {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 1.9vw, 24px);
    line-height: 1.45;
    color: white;
    max-width: 720px;
    letter-spacing: -0.005em;
    text-shadow: 0 2px 16px rgba(0,0,0,0.7);
  }
  .cinema-em { color: var(--yellow); font-weight: 500; }
  .impacto-note {
    margin: 32px auto 0;
    max-width: 640px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-faint);
    text-align: center;
  }

  @media (max-width: 900px) {
    .metricas-big .grid { grid-template-columns: repeat(2, 1fr); }
    .metricas-big .met:nth-child(3) { border-left: none; }
  }
  @media (max-width: 700px) {
    .cinema-wrap { padding: 0 16px; }
    .cinema-card { aspect-ratio: 4 / 5; border-radius: 20px; }
    .cinema-content { padding: 28px 24px 32px; }
    .cinema-quote-mark { font-size: 60px; margin-bottom: 12px; }
    .cinema-pull {
      font-size: clamp(34px, 11vw, 52px);
      margin-bottom: 16px;
    }
    .cinema-rest { font-size: 17px; }
    .cinema-overlay {
      background:
        linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 25%, rgba(0,0,0,0.6) 55%, rgba(0,0,0,0.97) 100%);
    }
  }
  @media (max-width: 500px) {
    .metricas-big .grid { grid-template-columns: 1fr; gap: 24px; }
    .metricas-big .met { border-left: none; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 24px; }
    .metricas-big .met:first-child { border-top: none; padding-top: 0; }
  }
</style>

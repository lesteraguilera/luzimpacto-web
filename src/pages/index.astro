---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Metricas from "../components/Metricas.astro";
import About from "../components/About.astro";
import Pilares from "../components/Pilares.astro";
import ProximosEventos from "../components/ProximosEventos.astro";
import Aliadas from "../components/Aliadas.astro";
import MapaCR from "../components/MapaCR.astro";
import Testimonio from "../components/Testimonio.astro";
import SumateTeaser from "../components/SumateTeaser.astro";
import CTAFinal from "../components/CTAFinal.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="LUZ Impacto — Llevamos el Amor de Cristo a los colegios de Costa Rica"
  description="Ministerio cristiano evangélico costarricense. Visitamos colegios con el mensaje de salvación y conectamos a los jóvenes con iglesias locales. 60+ colegios visitados, 50K+ jóvenes alcanzados."
>
  <Header />
  <Hero />
  <Metricas />
  <About />
  <ProximosEventos />
  <Pilares />
  <Aliadas />
  <section class="section-mapa">
    <div class="container">
      <MapaCR />
    </div>
  </section>

  <style>
    .section-mapa { padding: 100px 0; }
    @media (max-width: 600px) { .section-mapa { padding: 64px 0; } }
  </style>
  <Testimonio />
  <SumateTeaser />
  <CTAFinal />
  <Footer />
</BaseLayout>

---
// Header sticky con logo + nav + lang toggle + CTA + drawer móvil
import LanguageToggle from "./LanguageToggle.astro";
import { getLang } from "../lib/i18n";

const lang = getLang(Astro.url);
const isEn = lang === "en";

const t = {
  homeLabel: isEn ? "Home" : "Inicio",
  about: isEn ? "About" : "Nosotros",
  whatWeDo: isEn ? "What we do" : "Qué hacemos",
  impact: isEn ? "Impact" : "Impacto",
  photos: isEn ? "Photos" : "Fotos",
  contact: isEn ? "Contact" : "Contacto",
  getInvolved: isEn ? "Get involved" : "Sumate",
  joinMission: isEn ? "Join the mission" : "Sumate a la misión",
  openMenu: isEn ? "Open menu" : "Abrir menú",
  closeMenu: isEn ? "Close menu" : "Cerrar menú",
  homeAria: isEn ? "LUZ Impacto · Home" : "LUZ Impacto · Inicio",
};

const paths = {
  home: isEn ? "/en/" : "/",
  about: isEn ? "/en/about" : "/nosotros",
  whatWeDo: isEn ? "/en/what-we-do" : "/que-hacemos",
  impact: isEn ? "/en/impact" : "/impacto",
  photos: isEn ? "/en/photos" : "/fotos",
  contact: isEn ? "/en/contact" : "/contacto",
  getInvolved: isEn ? "/en/get-involved" : "/sumate",
};
---

<header class="site-header">
  <div class="container">
    <a href={paths.home} class="header-logo" aria-label={t.homeAria}>
      <span class="luz-logo-img size-sm"></span>
    </a>
    <nav class="nav-main">
      <a href={paths.about}>{t.about}</a>
      <a href={paths.whatWeDo}>{t.whatWeDo}</a>
      <a href={paths.impact}>{t.impact}</a>
      <a href={paths.photos}>{t.photos}</a>
      <a href={paths.contact}>{t.contact}</a>
    </nav>
    <div class="nav-tools">
      <LanguageToggle />
      <a href={paths.getInvolved} class="btn btn-dark btn-sm">{t.getInvolved} <span class="arrow">→</span></a>
      <button class="nav-toggle" aria-label={t.openMenu} aria-expanded="false" id="navToggle">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Drawer fuera del header para evitar stacking-context bug -->
<div class="nav-drawer" id="navDrawer" aria-hidden="true">
  <button class="drawer-close" id="drawerClose" aria-label={t.closeMenu} type="button">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>
  <div class="drawer-scroll">
    <div class="drawer-inner">
      <div class="drawer-lang">
        <LanguageToggle />
      </div>
      <a href={paths.home}>{t.homeLabel}</a>
      <a href={paths.about}>{t.about}</a>
      <a href={paths.whatWeDo}>{t.whatWeDo}</a>
      <a href={paths.impact}>{t.impact}</a>
      <a href={paths.photos}>{t.photos}</a>
      <a href={paths.contact}>{t.contact}</a>
      <div class="drawer-ctas">
        <a href={paths.getInvolved} class="btn btn-yellow drawer-cta">{t.joinMission} <span class="arrow">→</span></a>
        <a href="https://wa.me/50685493929" class="btn btn-ghost-dark drawer-cta" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const toggle = document.getElementById('navToggle');
    const drawer = document.getElementById('navDrawer');
    const closeBtn = document.getElementById('drawerClose');
    if (!toggle || !drawer) return;
    const setState = (open) => {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
      document.body.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') !== 'true';
      setState(open);
    });
    if (closeBtn) closeBtn.addEventListener('click', () => setState(false));
    drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setState(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') setState(false);
    });
  })();
</script>

<style>
  .site-header {
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
    background: rgba(250,247,242,0.92);
  }
  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .header-logo { text-decoration: none; }
  .nav-main {
    display: flex;
    gap: 32px;
    flex: 1;
    justify-content: center;
  }
  .nav-main a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-main a:hover { color: var(--charcoal); }
  .nav-tools {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .lang-toggle {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
  }
  .lang-toggle .active { color: var(--charcoal); }

  .nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 8px;
    position: relative;
  }
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--charcoal);
    margin: 5px 0;
    transition: transform 0.25s, opacity 0.25s;
    border-radius: 2px;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-drawer {
    position: fixed;
    inset: 0;
    height: 100dvh;
    background: var(--bg);
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 150;
    visibility: hidden;
    overflow: hidden;
  }
  .drawer-scroll {
    height: 100%;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding-top: 80px;
  }
  .nav-drawer[aria-hidden="false"] {
    transform: translateY(0);
    visibility: visible;
  }
  .drawer-inner {
    padding: 40px 32px calc(120px + env(safe-area-inset-bottom, 0px));
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .drawer-lang {
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }
  .drawer-lang :global(.lang-toggle) {
    font-size: 14px;
  }
  .drawer-inner > a:not(.btn) {
    font-family: "Fraunces", serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    letter-spacing: -0.01em;
  }
  .drawer-ctas {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-bottom: none !important;
    padding: 0 !important;
  }
  .drawer-cta {
    font-family: "Inter", sans-serif !important;
    font-size: 16px !important;
    padding: 16px 26px !important;
    align-self: stretch;
    text-align: center;
    justify-content: center;
    box-sizing: border-box;
    min-height: 54px;
    display: inline-flex;
    align-items: center;
  }

  .drawer-close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 44px;
    height: 44px;
    border: none;
    background: rgba(250,247,242,0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    z-index: 10;
    color: var(--charcoal);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .drawer-close svg { width: 22px; height: 22px; }
  .drawer-close:hover { background: rgba(31,33,37,0.08); }
  .drawer-close:active { transform: scale(0.92); }

  @media (max-width: 900px) {
    .nav-main { display: none; }
    .nav-tools .lang-toggle { display: none; }
    .nav-tools .btn { display: none; }
    .nav-toggle { display: block; }
  }
</style>

---
// Layout principal del sitio
// Recibe: title, description (opcional)
import "../styles/global.css";
import FloatingDonate from "../components/FloatingDonate.astro";
import DonarModal from "../components/DonarModal.astro";

const {
  title = "LUZ Impacto — Llevamos el Amor de Cristo a los colegios",
  description = "Fundación LUZ Impacto: ministerio cristiano evangélico costarricense. Visitamos colegios con un mensaje de salvación y conectamos a los jóvenes con iglesias locales que los discipulen.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://luzimpacto.org").toString();

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "NGO",
  "name": "Fundación LUZ Impacto",
  "alternateName": "LUZ Impacto",
  "url": "https://luzimpacto.org",
  "logo": "https://luzimpacto.org/assets/logos/luz.png",
  "image": "https://luzimpacto.org/og-image.jpg",
  "description": "Ministerio cristiano evangélico costarricense que visita colegios con un mensaje de salvación y conecta a los jóvenes con iglesias locales para su discipulado.",
  "foundingDate": "2024",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "San José",
    "addressCountry": "CR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "samuel@luzimpacto.org",
    "telephone": "+506-8549-3929",
    "contactType": "customer service",
    "areaServed": "CR",
    "availableLanguage": "Spanish"
  },
  "sameAs": [
    "https://instagram.com/luzimpacto_cr"
  ]
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="theme-color" content="#1F2125" />
  <meta name="author" content="Fundación LUZ Impacto" />
  <meta name="keywords" content="LUZ Impacto, ministerio cristiano, evangelio en colegios, Costa Rica, evangelismo juvenil, fundación cristiana" />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:site_name" content="LUZ Impacto" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://luzimpacto.org/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Llevamos el Amor de Cristo a los colegios — Fundación LUZ Impacto" />
  <meta property="og:locale" content="es_CR" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://luzimpacto.org/og-image.jpg" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/assets/logos/luz.png" />

  <!-- Preload hero poster (LCP) — solo en home -->
  {Astro.url.pathname === "/" && (
    <link rel="preload" as="image" href="/assets/photos/hero-poster.jpg" fetchpriority="high" />
  )}

  <!-- Google Fonts: Fraunces + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />

  <FloatingDonate />
  <DonarModal />

  <!-- Animación de números (Intersection Observer) -->
  <script is:inline>
    (function() {
      const counters = document.querySelectorAll('.count');
      const animate = (el) => {
        const target = parseInt(el.dataset.target, 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1600;
        const start = performance.now();
        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          if (progress >= 1) {
            el.textContent = target + suffix;
            return;
          }
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(eased * target) + suffix;
          requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      if ('IntersectionObserver' in window) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting && !e.target.dataset.done) {
              e.target.dataset.done = '1';
              animate(e.target);
            }
          });
        }, { threshold: 0.4 });
        counters.forEach((c) => obs.observe(c));
      } else {
        counters.forEach(animate);
      }
    })();
  </script>
</body>
</html>


---
// Layout principal del sitio — soporte ES/EN
import "../styles/global.css";
import FloatingDonate from "../components/FloatingDonate.astro";
import DonarModal from "../components/DonarModal.astro";
import { getLang, getAlternatePath } from "../lib/i18n";

const lang = getLang(Astro.url);
const isEn = lang === "en";

const defaults = {
  es: {
    title: "LUZ Impacto — Llevamos el Amor de Cristo a los colegios",
    description: "Fundación LUZ Impacto: ministerio cristiano evangélico costarricense. Visitamos colegios con un mensaje de salvación y conectamos a los jóvenes con iglesias locales que los discipulen.",
    keywords: "LUZ Impacto, ministerio cristiano, evangelio en colegios, Costa Rica, evangelismo juvenil, fundación cristiana",
    ogAlt: "Llevamos el Amor de Cristo a los colegios — Fundación LUZ Impacto",
    locale: "es_CR",
  },
  en: {
    title: "LUZ Impacto — Bringing Christ's love to Costa Rica's schools",
    description: "LUZ Impacto Foundation: a Costa Rican evangelical Christian ministry. We visit schools with the message of salvation and connect young people with local churches to disciple them.",
    keywords: "LUZ Impacto, Christian ministry, school evangelism, Costa Rica, youth ministry, Christian foundation",
    ogAlt: "Bringing Christ's love to Costa Rica's schools — LUZ Impacto Foundation",
    locale: "en_US",
  },
};

const {
  title = defaults[lang].title,
  description = defaults[lang].description,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://luzimpacto.org").toString();
const alternatePath = getAlternatePath(Astro.url.pathname);
const alternateURL = new URL(alternatePath, Astro.site || "https://luzimpacto.org").toString();

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "NGO",
  "name": "Fundación LUZ Impacto",
  "alternateName": "LUZ Impacto",
  "url": "https://luzimpacto.org",
  "logo": "https://luzimpacto.org/assets/logos/luz.png",
  "image": "https://luzimpacto.org/og-image.jpg",
  "description": isEn
    ? "Costa Rican evangelical Christian ministry that visits schools with the message of salvation and connects young people with local churches for discipleship."
    : "Ministerio cristiano evangélico costarricense que visita colegios con un mensaje de salvación y conecta a los jóvenes con iglesias locales para su discipulado.",
  "foundingDate": "2024",
  "nonprofitStatus": "Nonprofit501c3",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "San José",
    "addressCountry": "CR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "samuel@luzimpacto.org",
    "telephone": "+506-8549-3929",
    "contactType": "customer service",
    "areaServed": "CR",
    "availableLanguage": ["Spanish", "English"]
  },
  "sameAs": [
    "https://instagram.com/luzimpacto_cr"
  ]
};
---

<!DOCTYPE html>
<html lang={isEn ? "en" : "es"}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Hreflang alternates -->
  <link rel="alternate" hreflang={isEn ? "es" : "en"} href={alternateURL} />
  <link rel="alternate" hreflang="x-default" href="https://luzimpacto.org/" />

  <meta name="theme-color" content="#1F2125" />
  <meta name="author" content="Fundación LUZ Impacto" />
  <meta name="keywords" content={defaults[lang].keywords} />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:site_name" content="LUZ Impacto" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://luzimpacto.org/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={defaults[lang].ogAlt} />
  <meta property="og:locale" content={defaults[lang].locale} />
  <meta property="og:locale:alternate" content={isEn ? "es_CR" : "en_US"} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://luzimpacto.org/og-image.jpg" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>

  <!-- Favicons (cuadrados, logo centrado con padding — no usar el luz.png 677x423 que se ve aplastado) -->
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/logos/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/logos/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/logos/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/logos/favicon-192.png" />

  <!-- Preload hero poster (LCP) — solo en home (ES o EN) -->
  {(Astro.url.pathname === "/" || Astro.url.pathname === "/en/" || Astro.url.pathname === "/en") && (
    <link rel="preload" as="image" href="/assets/photos/hero-poster.jpg" fetchpriority="high" />
  )}

  <!-- Google Fonts: Fraunces + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />

  <FloatingDonate />
  <DonarModal />

  <!-- Animación de números (Intersection Observer) — el HTML estático ya trae el valor final; este script solo anima -->
  <script is:inline>
    (function() {
      const counters = document.querySelectorAll('.count');
      if (!counters.length) return;
      const reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced || !('IntersectionObserver' in window)) return; // HTML ya tiene el valor final

      const animate = (el) => {
        const target = parseInt(el.dataset.target, 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1600;
        const start = performance.now();
        el.textContent = '0' + suffix;
        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          if (progress >= 1) { el.textContent = target + suffix; return; }
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(eased * target) + suffix;
          requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !e.target.dataset.done) {
            e.target.dataset.done = '1';
            animate(e.target);
          }
        });
      }, { threshold: 0.4 });
      counters.forEach((c) => obs.observe(c));
    })();
  </script>
</body>
</html>

---
// Modal de donación — se abre cuando alguien hace click en cualquier botón con href="#donar"
// 2 métodos directos (SINPE Móvil, IBAN) + coordinación por WhatsApp para donantes internacionales.
import { getLang } from "../lib/i18n";
const lang = getLang(Astro.url);
const isEn = lang === "en";

const t = {
  closeAria: isEn ? "Close" : "Cerrar",
  eyebrow: isEn ? "Every colón reaches a school" : "Cada colón viaja a un colegio",
  title: isEn ? "How to give" : "Cómo donar",
  lede: isEn
    ? "Your donation covers transportation, materials, and events where young people hear the gospel."
    : "Tu donación cubre transporte, materiales y eventos donde los jóvenes escuchan el evangelio.",
  founderRole: isEn ? "Founder" : "Fundador",
  founderQuote: isEn
    ? `"Every donation goes directly to a school. Thank you for joining this mission."`
    : `"Cada donación llega directo a un colegio. Gracias por sumarte a esta misión."`,
  impactEyebrow: isEn ? "What your donation does" : "Lo que tu donación logra",
  tier1: isEn ? "Materials for a group of young people to receive the message" : "Materiales para que un grupo de jóvenes reciba el mensaje",
  tier2: isEn ? "Transportation and materials for one school visit" : "Transporte y materiales para una visita a un colegio",
  tier3: isEn ? "A complete event: equipment, sound, materials, and refreshments" : "Un evento completo: equipo, sonido, materiales y refrigerio",
  monthlyLink: isEn ? "🔁 Want to give monthly?" : "🔁 ¿Querés ser donante mensual?",
  monthlyHref: isEn
    ? "https://wa.me/50685493929?text=Hello%20LUZ%2C%20I%20want%20to%20become%20a%20monthly%20donor"
    : "https://wa.me/50685493929?text=Hola%20LUZ%2C%20quiero%20ser%20donante%20mensual",
  sinpeTag: isEn ? "Costa Rica · fastest" : "Costa Rica · más rápido",
  ibanTag: isEn ? "Costa Rica · bank transfer" : "Costa Rica · transferencia",
  ibanName: isEn ? "Cuenta IBAN" : "Cuenta IBAN",
  numberLabel: isEn ? "Number" : "Número",
  accountHolderLabel: isEn ? "Account holder" : "A nombre de",
  ibanLabel: isEn ? "IBAN" : "IBAN",
  copiedText: isEn ? "Copied! ✓" : "¡Copiado! ✓",
  intlTag: isEn ? "International · USD" : "Internacional · USD",
  intlTitle: isEn ? "Donating from outside Costa Rica?" : "¿Donás desde fuera de Costa Rica?",
  intlDesc: isEn
    ? "We're setting up PayPal and Wise in the Foundation's name. Meanwhile, we coordinate your international donation by WhatsApp."
    : "Estamos habilitando PayPal y Wise a nombre de la Fundación. Mientras tanto, coordinamos tu donación internacional por WhatsApp.",
  intlCta: isEn ? "Message us on WhatsApp" : "Escribir por WhatsApp",
  intlWa: isEn
    ? "https://wa.me/50685493929?text=Hello%20LUZ%2C%20I%20want%20to%20donate%20from%20abroad"
    : "https://wa.me/50685493929?text=Hola%20LUZ%2C%20quiero%20donar%20desde%20el%20exterior",
  footLine: isEn ? "Prefer to talk first?" : "¿Preferís hablar primero?",
  footLink: isEn ? "Message us on WhatsApp" : "Escribinos por WhatsApp",
  footWa: isEn
    ? "https://wa.me/50685493929?text=Hello%20LUZ%2C%20I%20want%20to%20donate"
    : "https://wa.me/50685493929?text=Hola%20LUZ%2C%20quiero%20donar",
};
---

<div class="donar-modal" id="donarModal" aria-hidden="true" role="dialog" aria-labelledby="donarTitle">
  <div class="modal-backdrop" data-close></div>
  <div class="modal-panel">
    <button class="modal-close" aria-label={t.closeAria} data-close>×</button>
    <div class="modal-scroll">

    <div class="modal-eyebrow">{t.eyebrow}</div>
    <h2 id="donarTitle">{t.title}</h2>
    <p class="modal-lede">{t.lede}</p>

    <div class="founder-note">
      <img src="/assets/photos/equipo/samuel.jpg" alt="Samuel Pizzo, fundador de LUZ Impacto" loading="lazy" />
      <div class="founder-text">
        <div class="founder-name"><strong>Samuel Pizzo</strong> · {t.founderRole}</div>
        <p>{t.founderQuote}</p>
      </div>
    </div>

    <div class="impacto-amounts">
      <div class="impacto-eyebrow">{t.impactEyebrow}</div>
      <div class="impacto-tiers">
        <div class="impacto-tier">
          <div class="tier-amount"><span class="tier-cur">₡</span>5,000<span class="tier-usd">≈ $10</span></div>
          <div class="tier-impact">{t.tier1}</div>
        </div>
        <div class="impacto-tier tier-featured">
          <div class="tier-amount"><span class="tier-cur">₡</span>20,000<span class="tier-usd">≈ $40</span></div>
          <div class="tier-impact">{t.tier2}</div>
        </div>
        <div class="impacto-tier">
          <div class="tier-amount"><span class="tier-cur">₡</span>75,000<span class="tier-usd">≈ $150</span></div>
          <div class="tier-impact">{t.tier3}</div>
        </div>
      </div>
      <a href={t.monthlyHref} target="_blank" rel="noopener" class="mensual-link">
        {t.monthlyLink} <span class="mensual-arrow">→</span>
      </a>
    </div>

    <div class="donar-options">
      <div class="donar-opt">
        <div class="opt-head">
          <div class="opt-tag">{t.sinpeTag}</div>
          <h3>SINPE Móvil</h3>
        </div>
        <div class="opt-data">
          <div class="data-row">
            <span class="data-label">{t.numberLabel}</span>
            <button class="data-value" data-copy="85493929">8549 3929 <span class="copy-ico">⧉</span></button>
          </div>
          <div class="data-row">
            <span class="data-label">{t.accountHolderLabel}</span>
            <span class="data-value-static">Fundación LUZ Impacto</span>
          </div>
        </div>
      </div>

      <div class="donar-opt">
        <div class="opt-head">
          <div class="opt-tag">{t.ibanTag}</div>
          <h3>{t.ibanName}</h3>
        </div>
        <div class="opt-data">
          <div class="data-row">
            <span class="data-label">{t.ibanLabel}</span>
            <button class="data-value" data-copy="CR10015110720010495519">CR10 0151 1072 0010 4955 19 <span class="copy-ico">⧉</span></button>
          </div>
          <div class="data-row">
            <span class="data-label">{t.accountHolderLabel}</span>
            <span class="data-value-static">Fundación LUZ Impacto</span>
          </div>
        </div>
      </div>

      <div class="donar-opt opt-international">
        <div class="opt-head">
          <div class="opt-tag">{t.intlTag}</div>
          <h3>{t.intlTitle}</h3>
        </div>
        <div class="opt-data">
          <p class="opt-desc">{t.intlDesc}</p>
          <a href={t.intlWa} target="_blank" rel="noopener" class="btn btn-dark btn-sm">{t.intlCta} <span class="arrow">→</span></a>
        </div>
      </div>
    </div>

    <div class="modal-foot">
      {t.footLine} <a href={t.footWa} target="_blank" rel="noopener">{t.footLink}</a>
    </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const init = () => {
      const modal = document.getElementById('donarModal');
      if (!modal) return;

      const open = () => {
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };
      const close = () => {
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      // Event delegation a nivel documento — captura links agregados dinámicamente
      document.addEventListener('click', (e) => {
        const a = e.target.closest && e.target.closest('a[href="#donar"]');
        if (a) {
          e.preventDefault();
          open();
          return;
        }
        const closer = e.target.closest && e.target.closest('[data-close]');
        if (closer && modal.contains(closer)) {
          close();
          return;
        }
        const copyBtn = e.target.closest && e.target.closest('[data-copy]');
        if (copyBtn) {
          const val = copyBtn.getAttribute('data-copy');
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(val).then(() => {
              const orig = copyBtn.innerHTML;
              const isEn = location.pathname.startsWith('/en');
              copyBtn.innerHTML = isEn ? 'Copied! ✓' : '¡Copiado! ✓';
              copyBtn.classList.add('copied');
              setTimeout(() => { copyBtn.innerHTML = orig; copyBtn.classList.remove('copied'); }, 1500);
            }).catch(() => {
              // Fallback: seleccionar texto
              const r = document.createRange();
              r.selectNodeContents(copyBtn);
              const sel = window.getSelection();
              sel.removeAllRanges();
              sel.addRange(r);
            });
          }
        }
      });

      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .donar-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.25s, visibility 0.25s;
  }
  .donar-modal[aria-hidden="false"] {
    visibility: visible;
    opacity: 1;
  }
  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(31,33,37,0.65);
    backdrop-filter: blur(4px);
  }
  .modal-panel {
    position: relative;
    background: var(--bg);
    border-radius: 24px;
    max-width: 640px;
    width: 100%;
    max-height: 90vh;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.3);
    border-top: 4px solid var(--yellow);
    display: flex;
    flex-direction: column;
  }
  .modal-scroll {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 48px 48px 32px;
    flex: 1;
  }
  .modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 40px;
    height: 40px;
    border: none;
    background: rgba(250,247,242,0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 26px;
    line-height: 1;
    color: var(--charcoal);
    cursor: pointer;
    border-radius: 50%;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: background 0.15s, transform 0.15s;
  }
  .modal-close:hover { background: rgba(31,33,37,0.08); }
  .modal-close:active { transform: scale(0.92); }

  .modal-eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 10px;
  }
  #donarTitle {
    font-family: "Fraunces", serif;
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .modal-lede {
    font-size: 16px;
    color: var(--ink-soft);
    margin-bottom: 20px;
    line-height: 1.55;
  }

  .founder-note {
    display: flex;
    gap: 14px;
    align-items: center;
    padding: 14px 16px;
    background: var(--crema);
    border-radius: 12px;
    margin-bottom: 24px;
    border: 1px solid var(--line);
  }
  .founder-note img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 30%;
    flex-shrink: 0;
    border: 2px solid var(--yellow);
  }
  .founder-text { flex: 1; min-width: 0; }
  .founder-name {
    font-size: 12px;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    margin-bottom: 4px;
  }
  .founder-name strong {
    color: var(--charcoal);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .founder-text p {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--ink);
    margin: 0;
  }

  .impacto-amounts {
    background: var(--crema);
    border-radius: 14px;
    padding: 18px 20px;
    margin-bottom: 24px;
    border-left: 3px solid var(--yellow);
  }
  .impacto-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 12px;
  }
  .impacto-tiers {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .impacto-tier {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 16px;
    align-items: center;
    padding: 10px 12px;
    border-radius: 10px;
    background: white;
    border: 1px solid var(--line);
  }
  .impacto-tier.tier-featured {
    background: rgba(252,211,77,0.10);
    border-color: var(--yellow);
  }
  .tier-amount {
    font-family: "Fraunces", serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--charcoal);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .tier-cur { color: var(--yellow); font-weight: 700; margin-right: 2px; }
  .tier-usd {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-faint);
    margin-left: 8px;
    letter-spacing: 0;
  }
  .tier-impact {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.45;
  }
  .mensual-link {
    display: block;
    text-align: center;
    margin-top: 14px;
    padding: 12px 16px;
    background: white;
    border: 1px dashed var(--yellow);
    border-radius: 10px;
    color: var(--charcoal);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.2s;
  }
  .mensual-link:hover {
    background: var(--yellow-soft, rgba(252,211,77,0.12));
  }
  .mensual-arrow {
    color: var(--charcoal);
    font-weight: 400;
    margin-left: 4px;
  }

  @media (max-width: 500px) {
    .impacto-tier { grid-template-columns: 1fr; gap: 4px; padding: 12px; }
    .tier-amount { font-size: 18px; }
  }

  .donar-options {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .donar-opt {
    background: white;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid var(--line);
  }
  .opt-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 6px;
  }
  .donar-opt h3 {
    font-family: "Fraunces", serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .opt-data { display: flex; flex-direction: column; gap: 10px; }
  .data-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .data-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .data-value {
    font-family: "Fraunces", serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
    background: var(--crema);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 8px 12px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s, border-color 0.2s;
    font-variant-numeric: tabular-nums;
  }
  .data-value:hover { background: var(--yellow-soft); border-color: var(--yellow); }
  .data-value.copied { background: var(--yellow); border-color: var(--yellow); color: var(--charcoal); }
  .data-value-static {
    font-family: "Fraunces", serif;
    font-size: 16px;
    color: var(--ink);
    font-weight: 500;
  }
  .copy-ico { font-size: 14px; opacity: 0.6; }

  .opt-international .opt-desc { font-size: 14px; color: var(--ink-soft); margin-bottom: 14px; line-height: 1.5; }

  .modal-foot {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    text-align: center;
    font-size: 14px;
    color: var(--ink-soft);
  }
  .modal-foot a { color: var(--charcoal); font-weight: 600; text-decoration: underline; }

  @media (max-width: 600px) {
    .modal-panel { border-radius: 20px; }
    .modal-scroll { padding: 36px 24px 24px; }
    #donarTitle { font-size: 32px; }
    .data-row { flex-direction: column; align-items: flex-start; gap: 4px; }
    .data-value { font-size: 15px; }
  }
</style>

---
// Footer limpio (solo links que funcionan)
import { getLang } from "../lib/i18n";

const lang = getLang(Astro.url);
const isEn = lang === "en";

const t = {
  brandTagline: isEn
    ? "Costa Rican evangelical Christian ministry. Bringing Christ's love to schools since 2024."
    : "Ministerio cristiano evangélico costarricense. Llevamos el Amor de Cristo a los colegios desde 2024.",
  contactTitle: isEn ? "Contact" : "Contacto",
  followTitle: isEn ? "Follow us" : "Seguinos",
  supportTitle: isEn ? "Support us" : "Apoyá",
  joinCta: isEn ? "Join the mission" : "Sumate a la misión",
  verse: isEn
    ? '"You are the light of the world." — Matthew 5:14'
    : '"Vosotros sois la luz del mundo." — Mateo 5:14',
  beliefs: isEn ? "What we believe" : "Lo que creemos",
  forChurches: isEn ? "For churches" : "Para iglesias",
  privacy: isEn ? "Privacy" : "Privacidad",
  terms: isEn ? "Terms" : "Términos",
  getInvolvedPath: isEn ? "/en/get-involved" : "/sumate",
  beliefsPath: isEn ? "/en/what-we-believe" : "/lo-que-creemos",
  forChurchesPath: isEn ? "/en/for-churches" : "/para-iglesias",
  privacyPath: isEn ? "/en/privacy" : "/privacidad",
  termsPath: isEn ? "/en/terms" : "/terminos",
  contactId: isEn ? "contact" : "contacto",
};
---

<footer class="site-footer" id={t.contactId}>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="luz-logo-img size-md"></span>
        <p>{t.brandTagline}</p>
      </div>

      <div class="footer-col">
        <h4>{t.contactTitle}</h4>
        <a href="mailto:samuel@luzimpacto.org">samuel@luzimpacto.org</a>
        <a href="https://wa.me/50685493929" target="_blank" rel="noopener">WhatsApp +506 8549 3929</a>
        <span>San José, Costa Rica</span>
      </div>

      <div class="footer-col">
        <h4>{t.followTitle}</h4>
        <a href="https://instagram.com/luzimpacto_cr" target="_blank" rel="noopener">Instagram</a>
      </div>

      <div class="footer-col footer-cta">
        <h4>{t.supportTitle}</h4>
        <a href={t.getInvolvedPath} class="btn btn-yellow btn-sm">{t.joinCta} <span class="arrow">→</span></a>
      </div>
    </div>

    <div class="footer-verse">{t.verse}</div>

    <div class="footer-bottom">
      <div>© {new Date().getFullYear()} Fundación LUZ Impacto · {isEn ? "Founded 2024" : "Fundada 2024"} · San José, Costa Rica</div>
      <div class="footer-meta">
        <a href={t.beliefsPath}>{t.beliefs}</a>
        <span>·</span>
        <a href={t.forChurchesPath}>{t.forChurches}</a>
        <span>·</span>
        <a href={t.privacyPath}>{t.privacy}</a>
        <span>·</span>
        <a href={t.termsPath}>{t.terms}</a>
        <span>·</span>
        <span>luzimpacto.org</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--charcoal);
    color: var(--on-dark);
    padding: 80px 0 40px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  .footer-cta .btn {
    display: inline-flex;
    color: var(--charcoal) !important;
    font-weight: 700;
  }
  .footer-brand p {
    font-size: 14px;
    color: var(--on-dark-soft);
    max-width: 280px;
    line-height: 1.6;
    margin-top: 16px;
  }
  .footer-col h4 {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 16px;
  }
  .footer-col a, .footer-col span {
    display: block;
    color: var(--on-dark-soft);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 10px;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--yellow); }
  .footer-verse {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 40px 0 32px;
    text-align: center;
    font-family: "Fraunces", serif;
    font-style: italic;
    font-size: 18px;
    color: var(--yellow);
    letter-spacing: -0.005em;
  }
  .footer-bottom {
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.06);
    margin-top: 8px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 13px;
    color: var(--on-dark-soft);
    padding-top: 24px;
  }
  .footer-meta { display: flex; gap: 10px; align-items: center; }
  .footer-meta a { color: var(--on-dark-soft); text-decoration: none; }
  .footer-meta a:hover { color: var(--yellow); }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 600px) {
    .footer-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

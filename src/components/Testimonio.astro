---
import { getLang } from "../lib/i18n";
const lang = getLang(Astro.url);
const isEn = lang === "en";

const t = {
  sectionId: isEn ? "impact" : "impacto",
  eyebrow: isEn ? "Real stories" : "Historias reales",
  imgAlt: isEn
    ? "Group of students with a LUZ Impacto leader after an event at their school"
    : "Grupo de estudiantes con un líder de LUZ Impacto tras un evento en su colegio",
  pull: isEn ? "God reached me." : "Dios me agarró.",
  rest: isEn
    ? "That afternoon — I can't explain it any better. My friends and I cried like never before, and since that day we're different."
    : "Esa tarde no sé cómo explicarlo mejor. Mis amigas y yo lloramos como nunca, y desde ese día somos diferentes.",
  em: isEn
    ? "I'm not alone in what I was carrying anymore."
    : "Ya no me siento sola en lo que sentía.",
};
---

<section class="testimonio" id={t.sectionId}>
  <div class="container">
    <div class="testimonio-head">
      <div class="eyebrow center">{t.eyebrow}</div>
      {isEn ? (
        <h2>One school visit.<br><span class="highlight">One new family.</span></h2>
      ) : (
        <h2>Una visita a un colegio.<br><span class="highlight">Una familia</span> nueva.</h2>
      )}
    </div>
  </div>

  <div class="cinema-wrap">
    <div class="cinema-card">
      <img
        class="cinema-photo"
        src="/assets/photos/gallery/large/foto_44.jpg"
        alt={t.imgAlt}
        loading="lazy"
      />
      <div class="cinema-overlay"></div>
      <div class="cinema-content">
        <div class="cinema-pull">{t.pull}</div>
        <p class="cinema-rest">
          {t.rest} <span class="cinema-em">{t.em}</span>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonio {
    background: var(--charcoal);
    color: var(--on-dark);
    padding: 120px 0 100px;
    position: relative;
    overflow: hidden;
  }
  .testimonio::before {
    content: "";
    position: absolute;
    top: -100px;
    left: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(252,211,77,0.10) 0%, transparent 70%);
    pointer-events: none;
  }

  .testimonio-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 56px;
    position: relative;
    z-index: 1;
  }
  .testimonio-head .eyebrow.center { color: var(--yellow); margin-bottom: 16px; }
  .testimonio-head h2 {
    color: var(--on-dark);
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .highlight { color: var(--yellow); font-weight: 600; }

  .cinema-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
    z-index: 1;
  }
  .cinema-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    box-shadow: 0 30px 80px rgba(0,0,0,0.5);
  }
  .cinema-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }
  /* Overlay con scrim más fuerte abajo para legibilidad consistente */
  .cinema-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 30%, rgba(0,0,0,0.55) 65%, rgba(0,0,0,0.95) 100%);
    pointer-events: none;
  }
  .cinema-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 56px 64px;
    color: white;
    z-index: 2;
  }
  .cinema-quote-mark {
    font-family: "Fraunces", serif;
    font-size: 96px;
    line-height: 0.3;
    color: var(--yellow);
    opacity: 0.7;
    margin-bottom: 24px;
  }
  .cinema-pull {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-weight: 600;
    font-size: clamp(40px, 6vw, 84px);
    line-height: 1;
    color: var(--yellow);
    letter-spacing: -0.02em;
    margin-bottom: 22px;
    text-shadow: 0 4px 28px rgba(0,0,0,0.6);
  }
  .cinema-rest {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 1.9vw, 24px);
    line-height: 1.45;
    color: white;
    max-width: 720px;
    letter-spacing: -0.005em;
    text-shadow: 0 2px 16px rgba(0,0,0,0.7);
  }
  .cinema-em {
    color: var(--yellow);
    font-weight: 500;
  }

  @media (max-width: 700px) {
    .testimonio { padding: 80px 0 64px; }
    .cinema-wrap { padding: 0 16px; }
    .cinema-card { aspect-ratio: 4 / 5; border-radius: 20px; }
    .cinema-content { padding: 28px 24px 32px; }
    .cinema-quote-mark { font-size: 60px; margin-bottom: 12px; }
    .cinema-pull {
      font-size: clamp(34px, 11vw, 52px);
      margin-bottom: 16px;
    }
    .cinema-rest { font-size: 17px; }
    /* Scrim más agresivo en mobile para garantizar legibilidad */
    .cinema-overlay {
      background:
        linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 25%, rgba(0,0,0,0.6) 55%, rgba(0,0,0,0.97) 100%);
    }
  }
</style>
